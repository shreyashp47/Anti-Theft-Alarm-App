    <!-- Permission rationales -->
    <string name="permission_notifications_rationale">Notifications are used to keep the alarm service running in the background and alert you to security events.</string>
    <string name="permission_location_rationale">Location access enables geofence safe zones — the alarm won\'t trigger when you\'re at trusted locations like home.</string>
    <string name="permission_camera_rationale">Camera access allows the app to capture a photo of anyone who enters an incorrect PIN, helping identify intruders.</string>
    <string name="permission_phone_rationale">Phone state permission detects SIM card changes and helps notify trusted contacts if your device is tampered with.</string>
    <string name="permission_overlay_rationale">Drawing over other apps allows the alarm screen to appear on top of any app when a threat is detected.</string>
    <string name="permission_battery_rationale">Battery optimization exemption prevents Android from killing the alarm service, ensuring continuous protection.</string>
    <string name="permission_device_admin_rationale">Device Admin privileges prevent unauthorized uninstallation and add an extra layer of security against theft.</string>

